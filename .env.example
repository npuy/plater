# ==========================================
# Configuración del Backend
# ==========================================

# Puerto en el que corre el servidor Express
PORT=3000

# Entorno de ejecución
NODE_ENV=production

# ==========================================
# Configuración del Frontend
# ==========================================

# URL del backend (para desarrollo local)
VITE_API_URL=http://localhost:3000

# En producción (con Docker), el frontend hace proxy automático a través de Nginx
# No necesita variable especial ya que Nginx redirige /api al backend
